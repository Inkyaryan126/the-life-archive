+export async function createAccessLink(archiveSlug: string, expiresDays?: number) {
+  if (useSupabase) {
+    const supabase = createClient();
+    const {
+      data: { user },
+      error: userError,
+    } = await supabase.auth.getUser();
+
+    if (userError || !user) {
+      throw new Error("Authentication required to create access links.");
+    }
+
+    // Verify ownership
+    const { data: archive, error: archiveError } = await supabase
+      .from("archives")
+      .select("id, owner_id")
+      .eq("slug", archiveSlug)
+      .maybeSingle();
+
+    if (archiveError || !archive) {
+      throw new Error("Archive not found.");
+    }
+
+    if (archive.owner_id !== user.id) {
+      throw new Error("Only the archive owner can manage access links.");
+    }
+
+    const token = randomBytes(32).toString("hex");
+    const expiresAt = expiresDays
+      ? new Date(Date.now() + expiresDays * 24 * 60 * 60 * 1000).toISOString()
+      : null;
+
+    // Use admin client safely since permission is verified
+    const admin = createAdminClient();
+    const { data, error } = await (admin.from("access_links") as any)
+      .insert({
+        archive_id: (archive as any).id,
+        token,
+        expires_at: expiresAt,
+        created_by: user.id
+      })
+      .select()
+      .single();
+
+    if (error) throw error;
+    return data;
+  }
+
+  throw new Error("Supabase is required for access links.");
+}
+
+export async function softDeleteMemory(memoryId: string, archiveSlug: string) {
+  if (useSupabase) {
+    const supabase = createClient();
+    const {
+      data: { user },
+      error: userError,
+    } = await supabase.auth.getUser();
+
+    if (userError || !user) {
+      throw new Error("Authentication required to delete memories.");
+    }
+
+    // 1. Fetch archive and verify user has permission (Owner or Editor/Trustee)
+    const { data: archive, error: archiveError } = await supabase
+      .from("archives")
+      .select("id, owner_id")
+      .eq("slug", archiveSlug)
+      .maybeSingle();
+
+    if (archiveError || !archive) {
+      throw new Error("Archive not found.");
+    }
+
+    // Check if owner or editor/trustee member
+    const isOwner = archive.owner_id === user.id;
+    let hasEditPermission = isOwner;
+
+    if (!isOwner) {
+      const { data: membership } = await supabase
+        .from("archive_members")
+        .select("role")
+        .eq("archive_id", (archive as any).id)
+        .eq("user_id", user.id)
+        .maybeSingle();
+
+      hasEditPermission = membership?.role === "editor" || membership?.role === "trustee";
+    }
+
+    if (!hasEditPermission) {
+      throw new Error("You do not have permission to delete memories in this archive.");
+    }
+
+    // Verify memory exists inside this specific archive before updating (No arbitrary ID updates)
+    const { data: memory } = await supabase
+      .from("memories")
+      .select("id")
+      .eq("id", memoryId)
+      .eq("archive_id", (archive as any).id)
+      .maybeSingle();
+
+    if (!memory) {
+      throw new Error("Memory not found in this archive.");
+    }
+
+    // Perform soft-deletion
+    const admin = createAdminClient();
+    const { data, error } = await (admin.from("memories") as any)
+      .update({
+        deleted_at: new Date().toISOString(),
+        deleted_by: user.id
+      })
+      .eq("id", memoryId)
+      .select()
+      .single();
+
+    if (error) throw error;
+    return data;
+  }
+
+  throw new Error("Supabase is required for memory deletion.");
+}
+
+export async function restoreMemory(memoryId: string, archiveSlug: string) {
+  if (useSupabase) {
+    const supabase = createClient();
+    const {
+      data: { user },
+      error: userError,
+    } = await supabase.auth.getUser();
+
+    if (userError || !user) {
+      throw new Error("Authentication required to restore memories.");
+    }
+
+    // 1. Fetch archive and verify user has permission (Owner only for restoring!)
+    const { data: archive, error: archiveError } = await supabase
+      .from("archives")
+      .select("id, owner_id")
+      .eq("slug", archiveSlug)
+      .maybeSingle();
+
+    if (archiveError || !archive) {
+      throw new Error("Archive not found.");
+    }
+
+    // Only restore if the current user owns/admins the archive
+    const isOwner = archive.owner_id === user.id;
+    if (!isOwner) {
+      throw new Error("Only the archive owner can restore deleted memories.");
+    }
+
+    // Verify memory exists inside this specific archive before updating
+    const { data: memory } = await supabase
+      .from("memories")
+      .select("id")
+      .eq("id", memoryId)
+      .eq("archive_id", (archive as any).id)
+      .maybeSingle();
+
+    if (!memory) {
+      throw new Error("Memory not found in this archive.");
+    }
+
+    // Perform restore
+    const admin = createAdminClient();
+    const { data, error } = await (admin.from("memories") as any)
+      .update({
+        deleted_at: null,
+        deleted_by: null
+      })
+      .eq("id", memoryId)
+      .select()
+      .single();
+
+    if (error) throw error;
+    return data;
+  }
+
+  throw new Error("Supabase is required for memory restoration.");
+}
