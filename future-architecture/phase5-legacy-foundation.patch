@@ -33,5 +33,21 @@ export async function updateSession(request: NextRequest) {
 
   await supabase.auth.getClaims();
 
+  // Set secure archive access cookie if a ?token parameter is detected on an archive route
+  const url = new URL(request.url);
+  const token = url.searchParams.get("token");
+  const pathParts = url.pathname.split("/").filter(Boolean);
+
+  if (token && pathParts[0] === "archive" && pathParts[1]) {
+    const slug = pathParts[1];
+    response.cookies.set(`archive_access_${slug}`, token, {
+      path: "/",
+      maxAge: 60 * 60 * 24, // 1 day session duration
+      httpOnly: true,
+      secure: process.env.NODE_ENV === "production",
+      sameSite: "lax"
+    });
+  }
+
   return response;
 }
